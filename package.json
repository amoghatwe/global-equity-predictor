{
  "name": "global_equity_predictor",
  "version": "1.0.0",
  "description": "ML system for predicting 3-year forward equity market returns using macroeconomic indicators",
  "main": "run_prediction.py",
  "scripts": {
    "setup": "bash setup.sh",
    "test": "pytest tests/ -v",
    "train": "python run_prediction.py --mode train",
    "predict": "python run_prediction.py --mode predict --report console",
    "full": "python run_prediction.py --mode full --report html",
    "notebook": "jupyter notebook notebooks/"
  },
  "keywords": [
    "machine-learning",
    "finance",
    "asset-allocation",
    "macroeconomics",
    "equity-markets",
    "time-series",
    "forecasting"
  ],
  "author": "Your Name",
  "license": "MIT",
  "python_requires": ">=3.8",
  "repository": {
    "type": "git",
    "url": "your-repo-url"
  },
  "dependencies": {
    "core": [
      "pandas>=1.5.0",
      "numpy>=1.24.0",
      "scikit-learn>=1.3.0"
    ],
    "ml": [
      "xgboost>=2.0.0"
    ],
    "data": [
      "wbdata>=0.3.0",
      "fredapi>=0.5.0",
      "yfinance>=0.2.28"
    ],
    "viz": [
      "matplotlib>=3.7.0",
      "plotly>=5.15.0"
    ],
    "reporting": [
      "reportlab>=4.0.0",
      "jinja2>=3.1.0"
    ]
  }
}